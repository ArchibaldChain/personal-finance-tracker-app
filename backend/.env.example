DATABASE_URL=sqlite:///./finance.db
# Development
CORS_ORIGINS=["http://localhost:5173"]
# Production — replace with your Cloudflare Pages URL
# CORS_ORIGINS=["https://your-app.pages.dev"]

# LLM classification (optional — leave OPENAI_API_KEY empty to disable)
OPENAI_API_KEY=
CLASSIFICATION_ENABLED=true
CLASSIFICATION_MODEL=gpt-4o-mini

# Google Sign-In — paste your OAuth 2.0 Client ID here
GOOGLE_CLIENT_ID=

# JWT — generate a secret with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
JWT_EXPIRE_DAYS=30

# Set to true in development to allow local account sign-in (dev mode)
# Set to false in production
ALLOW_LOCAL_AUTH=false
